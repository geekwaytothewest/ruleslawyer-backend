{
  "name": "ruleslawyer-backend",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "CC-BY-4.0",
  "prisma": {
    "seed": "node dist/prisma/seed.js"
  },
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "postinstall": "DATABASE_URL=none prisma generate",
    "build": "nest build",
    "build:debug": "nest build -p tsconfig.debug.json",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start -p tsconfig.debug.json --debug 0.0.0.0:9229 --watch",
    "start:migrate:debug": "prisma migrate dev && nest start -p tsconfig.debug.json --debug 0.0.0.0:9229 --watch",
    "start:migrate:seed:debug": "prisma migrate dev && prisma db seed && nest start -p tsconfig.debug.json --debug 0.0.0.0:9229 --watch",
    "start:migrate:seed:debug:docker": "prisma generate && prisma migrate deploy && prisma db seed && nest start -p tsconfig.debug.json --debug 0.0.0.0:9229 --watch",
    "start:prod": "node dist/src/main",
    "start:migrate:prod": "prisma migrate deploy && node dist/prisma/seed.js && node dist/src/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json"
  },
  "dependencies": {
    "@fastify/multipart": "^10.0.0",
    "@fastify/static": "^9.1.3",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/common": "^11.1.24",
    "@nestjs/core": "^11.1.24",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.24",
    "@nestjs/platform-fastify": "^11.1.24",
    "@nestjs/swagger": "^11.4.4",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@types/adm-zip": "^0.5.8",
    "adm-zip": "^0.5.17",
    "ajv": "^8.20.0",
    "axios": "^1.17.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "cloc": "^2.6.0-cloc",
    "csv": "^6.5.1",
    "dotenv": "^17.4.2",
    "fast-xml-parser": "^5.8.0",
    "jwks-rsa": "^4.0.1",
    "nestjs-cls": "^6.2.1",
    "nestjs-http-promise": "^4.0.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.21.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "stringify": "^5.2.0",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@golevelup/ts-jest": "^3.0.0",
    "@mermaid-js/mermaid-cli": "^11.15.0",
    "@nestjs/cli": "^11.0.21",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.24",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.9.1",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "axios-mock-adapter": "^2.1.0",
    "cd": "^0.3.3",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "jest": "^30.4.2",
    "jest-mock-extended": "^4.0.1",
    "npm-check-updates": "^22.2.2",
    "prettier": "^3.8.3",
    "prisma": "^7.8.0",
    "prisma-erd-generator": "^2.4.3",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-loader": "^9.6.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "transformIgnorePatterns": [
      "/node_modules/(?!(jose|uuid)/)"
    ],
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "coveragePathIgnorePatterns": [
      "main.ts"
    ]
  },
  "overrides": {
    "@prisma/query-plan-executor": "7.8.0"
  },
  "allowScripts": {
    "@nestjs/core@11.1.24": true,
    "@prisma/client@7.8.0": true,
    "@scarf/scarf@1.4.0": true,
    "puppeteer@24.43.1": true,
    "prisma@7.8.0": true,
    "unrs-resolver@1.12.2": true,
    "@prisma/engines@7.8.0": true
  }
}
